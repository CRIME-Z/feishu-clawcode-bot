# Feishu ClawCode Bot Systemd Service
# 安装方法:
# 1. 复制到 NAS: /etc/systemd/system/feishu-bot.service
# 2. 执行: sudo systemctl daemon-reload
# 3. 启用: sudo systemctl enable feishu-bot
# 4. 启动: sudo systemctl start feishu-bot
# 5. 查看状态: sudo systemctl status feishu-bot

[Unit]
Description=Feishu ClawCode Bot - WebSocket Long Connection Mode
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=me
WorkingDirectory=/volume1/docker/feishu-clawcode-bot
ExecStart=/usr/bin/python3 bot/ws_client.py
Restart=on-failure
RestartSec=10
StandardOutput=append:/volume1/docker/feishu-clawcode-bot/bot.log
StandardError=append:/volume1/docker/feishu-clawcode-bot/bot_error.log

# 环境变量
Environment="PYTHONPATH=/volume1/docker/feishu-clawcode-bot"

# 软限制
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
