# ===========================================
# 飞书应用凭证（必填）
# ===========================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# ===========================================
# ClawCode / Agent 配置
# ===========================================
# claw-code (Rust 版) agent 命令路径（V2 使用）
# 默认: "agent"（需确保 $PATH 中有 agent 命令）
# 可通过 `which agent` 确认路径
AGENT_PATH=agent

# ===========================================
# ACP Agent API 配置（必填）
# ===========================================
# MiniMax API Key（从 ~/.zshrc 或环境变量获取）
AGENT_CODE_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxx

# MiniMax API 地址
AGENT_CODE_API_BASE_URL=https://api.minimaxi.com

# ===========================================
# 旧版 ClawCode 配置（V1，仅保留兼容）
# ===========================================
CLAWCODE_PATH=/Users/crime/clawcode
PYTHON_BIN=/Library/Frameworks/Python.framework/Versions/3.12/bin/python3.12

# ===========================================
# 服务配置
# ===========================================
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO
